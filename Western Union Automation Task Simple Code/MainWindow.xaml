<Window x:Class="Western_Union_Automation_Task_Simple_Code.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Western_Union_Automation_Task_Simple_Code"
        mc:Ignorable="d"
        Title="ParaBank RPA Automation" Height="700" Width="1080"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="ParaBank RPA Automation - Western Union Task" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Data selection -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Command="{Binding SelectCsvCommand}" Content="Load CSV File" Width="120" Margin="0,0,10,0" Cursor="Hand"/>
            <TextBlock Text="{Binding CsvPath}" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>
        
        <!-- Automation Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,26">
            <Button Command="{Binding StartAutomationCommand}" Content="Start Automation" 
                    Width="140" Height="30" Margin="0,0,10,0" Background="LightGreen" Cursor="Hand"/>
            <Button Content="Exit" Click="ExitButton_Click" Width="80" Height="30" Cursor="Hand"/>
        </StackPanel>

        <!-- Customers DataGrid -->
        <GroupBox Grid.Row="2" Header="Loaded Customers" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding Customers}" AutoGenerateColumns="True" IsReadOnly="True" 
                      MaxHeight="200" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>

        <!-- Log output -->
        <GroupBox Grid.Row="3" Header="Automation Log" Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding LogMessages}" ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <StatusBar Grid.Row="5" VerticalAlignment="Bottom">
            <StatusBarItem Content="{Binding Status}"/>
        </StatusBar>
    </Grid>
</Window>
